# Copie este arquivo para ".env" e preencha com os dados do seu app no Bling.
# (Bling -> Cadastros -> Aplicativos -> criar app do tipo OAuth)

BLING_CLIENT_ID=coloque_seu_client_id_aqui
BLING_CLIENT_SECRET=coloque_seu_client_secret_aqui

# Precisa ser EXATAMENTE igual ao "Link de redirecionamento" cadastrado no app do Bling.
BLING_REDIRECT_URI=http://localhost:8000/callback

# Mercado Livre (mensagens). Redirect PRECISA ser HTTPS.
ML_CLIENT_ID=coloque_seu_app_id_aqui
ML_CLIENT_SECRET=coloque_sua_secret_key_aqui
ML_REDIRECT_URI=https://SEU-ENDERECO/ml/callback

# Login do app (HTTP Basic). Em producao, defina uma senha forte.
# Se APP_PASSWORD ficar vazio, o login fica DESLIGADO (uso local).
APP_USER=admin
APP_PASSWORD=

# Banco de dados (producao). Se vazio, usa arquivos locais.
DATABASE_URL=
